# Gaming box shell — managed by Ansible.
# Run: ansible-playbook reset-configs.yml --tags shell to restore.

# PATH — prepend the box's ~/bin so interactive shells pick up the
# wrappers Ansible deploys there (cheat-engine, flycast-hires,
# xenia-canary-launch, etc.). Distrobox enter -- <cmd> doesn't load
# .zshrc, so for non-interactive direct invocation use the full path.
export PATH="$HOME/bin:$PATH"

# History
HISTFILE=~/.zsh_history
HISTSIZE=5000
SAVEHIST=5000
setopt appendhistory sharehistory hist_ignore_dups hist_ignore_space

# Completion
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select

# Key bindings (emacs mode)
bindkey -e

# Aliases
alias ls='ls --color=auto'
alias ll='ls -lah'
alias grep='grep --color=auto'

# Starship prompt
if command -v starship &>/dev/null; then
  export STARSHIP_LOG=error
  eval "$(starship init zsh)"
fi
