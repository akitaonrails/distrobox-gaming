#!/usr/bin/env sh
# cheat-engine — launch native Linux Cheat Engine.
#
# Native CE attaches via ptrace; Wine processes (Steam Proton games,
# CMR04 / OutRun / etc. via the pc_racing prefixes) are regular Linux
# processes from the kernel POV, so CE sees them in its process picker.
# No protontricks, no Wine prefix targeting required.
#
# DO NOT USE against VAC / EAC / BattlEye / multiplayer titles. Those
# anti-cheat systems will ban regardless of host OS.
#
# ptrace_scope: Arch defaults to kernel.yama.ptrace_scope=1 (only
# attach to descendants of the same shell). To attach to a Steam game
# you launched separately, you'll need either:
#   - One-time per session: sudo sysctl kernel.yama.ptrace_scope=0
#   - Persistent: drop a /etc/sysctl.d/99-ptrace.conf with
#       kernel.yama.ptrace_scope = 0
#   - Or per-binary capability:
#       sudo setcap cap_sys_ptrace=eip <DG_CHEATENGINE_EXE>
# This wrapper detects ptrace_scope and prints a hint if non-zero;
# CE itself will silently fail to attach otherwise.
set -eu

CE_DIR_DEFAULT="${HOME}/tools/cheat-engine/CheatEngineLinux766-4"
CE_DIR="${DG_CHEATENGINE_DIR:-$CE_DIR_DEFAULT}"
CE_EXE="$CE_DIR/cheatengine-x86_64"

[ -x "$CE_EXE" ] || {
  echo "Cheat Engine binary not found / not executable at: $CE_EXE" >&2
  echo "Run install-cheatengine.yml or set DG_CHEATENGINE_DIR." >&2
  exit 3
}

# ptrace_scope diagnostic
if [ -r /proc/sys/kernel/yama/ptrace_scope ]; then
  scope=$(cat /proc/sys/kernel/yama/ptrace_scope)
  if [ "$scope" != "0" ]; then
    cat >&2 <<EOF
[cheat-engine] kernel.yama.ptrace_scope=$scope (default on Arch is 1).
  CE may fail to attach to processes outside this terminal's tree
  (e.g. games launched from Steam). To allow attaches:
    one-shot:    sudo sysctl kernel.yama.ptrace_scope=0
    persistent:  echo 'kernel.yama.ptrace_scope = 0' | sudo tee /etc/sysctl.d/99-ptrace.conf
  Revert with kernel.yama.ptrace_scope=1.
EOF
  fi
fi

# CE looks for its sibling shared libraries via relative path, so the
# working directory has to be the archive root.
cd "$CE_DIR"
exec ./cheatengine-x86_64 "$@"
