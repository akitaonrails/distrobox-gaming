#!/usr/bin/env sh
set -eu

# Native Linux launcher for {{ item.name }} — runs inside the {{ dg_box_name }}
# box with no Wine. Managed by the install_native_games role.

game_dir="{{ item.game_dir }}"
launch_binary="$game_dir/{{ item.launch_binary }}"

if [ ! -x "$launch_binary" ]; then
  printf '%s\n' "ERROR: {{ item.name }} binary is missing or not executable: $launch_binary" >&2
{% if item.notes is defined %}  printf '%s\n' "NOTE: {{ item.notes }}" >&2
{% endif %}  exit 1
fi

# Compose the runtime library path, highest priority first:
#   1. system-SDL2 override (modern controller DB) under the old soname
#   2. the game's own bundled libs (libcurl / libcef / libpdf / SDL2_image)
#   3. the Steam scout runtime (old openssl-1.0 / idn / rtmp / ldap / gconf)
game_libs="$game_dir/{{ item.lib_subdir | default('lib/x86_64') }}"
lib_path="$game_libs"
{% if item.sdl2_override | default(false) -%}
lib_path="{{ dg_native_overrides_root }}/{{ item.slug }}:$lib_path"
{% endif -%}
{% if item.steam_runtime | default(false) -%}
runtime="{{ dg_native_steam_runtime }}"
lib_path="$lib_path:$runtime/amd64/lib/x86_64-linux-gnu:$runtime/usr/lib/x86_64-linux-gnu"
{% endif %}
cd "$game_dir"

# Inner mode: the game's library path and SDL hints must apply to the
# GAME ONLY, never to gamescope — the scout runtime ships an old
# libstdc++ that would break gamescope's own startup. So we re-exec this
# script as gamescope's child (or directly, without gamescope) and set
# the scoped environment only here.
if [ "${1:-}" = "--dg-inner" ]; then
  shift
  export LD_LIBRARY_PATH="$lib_path${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
  # Let the pad be seen even if the game window isn't focused (gamescope).
  export SDL_JOYSTICK_ALLOW_BACKGROUND_EVENTS=1
{% for env_var in item.env | default([]) %}  export {{ env_var.name }}="{{ env_var.value }}"
{% endfor %}{% if item.launch_script is defined %}  exec "./{{ item.launch_script }}" "$@"
{% else %}  exec "$launch_binary" "$@"
{% endif %}fi

{% if item.gamescope_enabled | default(true) -%}
if command -v gamescope >/dev/null 2>&1; then
  exec env -u PYTHONHOME -u PYTHONPATH gamescope \
    -W {{ item.gamescope_output_width | default(dg_native_gamescope_width) }} \
    -H {{ item.gamescope_output_height | default(dg_native_gamescope_height) }} \
    -w {{ item.gamescope_game_width | default(item.gamescope_output_width | default(dg_native_gamescope_width)) }} \
    -h {{ item.gamescope_game_height | default(item.gamescope_output_height | default(dg_native_gamescope_height)) }} \
    {% if item.gamescope_fullscreen | default(true) | bool -%}
    -f \
    {% endif -%}
    -- "$0" --dg-inner "$@"
fi
{% endif -%}
exec "$0" --dg-inner "$@"
