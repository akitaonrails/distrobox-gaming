#!/usr/bin/env sh
set -eu

prefix="{{ dg_pc_racing_prefix_root }}/{{ item.slug }}"
install_dir="{{ item.installed_path | default(dg_pc_racing_install_root ~ "/" ~ item.slug) }}"
exe="$install_dir/{{ item.launch_exe | default('') }}"

if [ ! -f "$exe" ]; then
  printf '%s\n' "ERROR: {{ item.name }} executable is missing: $exe" >&2
  printf '%s\n' "Run: {{ dg_box_home }}/bin/install-{{ item.slug }}" >&2
  {% if item.notes is defined -%}
  printf '%s\n' "NOTE: {{ item.notes }}" >&2
  {% endif -%}
  exit 1
fi

export PATH="{{ dg_pc_racing_wine_path }}"
export WINEPREFIX="$prefix"
export WINEARCH="{{ dg_pc_racing_winearch }}"
export WINEDEBUG="${WINEDEBUG:--all}"
export SDL_JOYSTICK_ALLOW_BACKGROUND_EVENTS=1
export SDL_JOYSTICK_HIDAPI="${SDL_JOYSTICK_HIDAPI:-{{ dg_pc_racing_sdl_hidapi }}}"
export SDL_GAMECONTROLLER_IGNORE_DEVICES_EXCEPT="${SDL_GAMECONTROLLER_IGNORE_DEVICES_EXCEPT:-{{ dg_pc_racing_gamepad_only }}}"
{% for env_var in item.env | default([]) -%}
export {{ env_var.name }}="{{ '${' }}{{ env_var.name }}:-{{ env_var.value }}{{ '}' }}"
{% endfor -%}
{% if dg_pc_racing_gamepad_device | length > 0 -%}
if [ -e "{{ dg_pc_racing_gamepad_device }}" ]; then
  export SDL_JOYSTICK_DEVICE="${SDL_JOYSTICK_DEVICE:-{{ dg_pc_racing_gamepad_device }}}"
fi
{% endif -%}

cd "$install_dir"
{% if item.gamescope_enabled | default(dg_pc_racing_gamescope_enabled) | bool -%}
if command -v gamescope >/dev/null 2>&1; then
  cleanup() {
    if [ -n "${gamescope_pid:-}" ]; then
      kill "$gamescope_pid" 2>/dev/null || true
    fi
    env -u PYTHONHOME -u PYTHONPATH wineserver -k >/dev/null 2>&1 || true
  }

  trap cleanup EXIT HUP INT TERM

  env -u PYTHONHOME -u PYTHONPATH gamescope \
    -W {{ item.gamescope_output_width | default(dg_pc_racing_gamescope_width) }} \
    -H {{ item.gamescope_output_height | default(dg_pc_racing_gamescope_height) }} \
    -w {{ item.gamescope_game_width | default(item.gamescope_output_width | default(dg_pc_racing_gamescope_width)) }} \
    -h {{ item.gamescope_game_height | default(item.gamescope_output_height | default(dg_pc_racing_gamescope_height)) }} \
    {% if item.gamescope_scaler is defined -%}
    -S {{ item.gamescope_scaler }} \
    {% endif -%}
    {% if item.gamescope_filter is defined -%}
    -F {{ item.gamescope_filter }} \
    {% endif -%}
    {% if item.gamescope_fullscreen | default(true) | bool -%}
    -f \
    {% elif item.gamescope_borderless | default(false) | bool -%}
    -b \
    {% endif -%}
    -- env -u PYTHONHOME -u PYTHONPATH \
      SDL_JOYSTICK_ALLOW_BACKGROUND_EVENTS="$SDL_JOYSTICK_ALLOW_BACKGROUND_EVENTS" \
      SDL_JOYSTICK_HIDAPI="$SDL_JOYSTICK_HIDAPI" \
      SDL_GAMECONTROLLER_IGNORE_DEVICES_EXCEPT="$SDL_GAMECONTROLLER_IGNORE_DEVICES_EXCEPT" \
      SDL_JOYSTICK_DEVICE="${SDL_JOYSTICK_DEVICE:-}" \
      wine "$exe" "$@" &
  gamescope_pid=$!
  set +e
  wait "$gamescope_pid"
  status=$?
  set -e
  trap - EXIT HUP INT TERM
  cleanup
  exit "$status"
fi
{% endif -%}
exec env -u PYTHONHOME -u PYTHONPATH wine "$exe" "$@"
