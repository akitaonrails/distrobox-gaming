#!/usr/bin/env sh
set -eu

# ES-DE launcher for the Model 2 Emulator (Wine). Managed by the
# install_m2emulator role.
#
# EMULATOR.EXE takes a ROM SET NAME (it resolves the zip itself via the
# [RomDirs] entries in EMULATOR.INI), not a path — so this wrapper
# accepts either form and reduces a %ROM% path to its basename.

install_dir="{{ dg_m2_install_dir }}"
exe="{{ dg_m2_exe }}"

if [ $# -lt 1 ]; then
  printf '%s\n' "usage: m2emulator-launch <rom.zip|romset-name>" >&2
  exit 64
fi

romset="$(basename "$1")"
romset="${romset%.zip}"
romset="${romset%.ZIP}"
shift

if [ ! -f "$install_dir/$exe" ]; then
  printf '%s\n' "ERROR: Model 2 Emulator missing: $install_dir/$exe" >&2
  printf '%s\n' "Run: ansible-playbook site.yml --tags m2emulator" >&2
  exit 1
fi

export WINEPREFIX="{{ dg_m2_prefix }}"
export WINEARCH=win64
export WINEDEBUG="${WINEDEBUG:--all}"

# Same SDL environment as the pc-racing launchers — wine's winebus SDL
# backend needs these to present the pads cleanly: no hidapi double-
# open, background events (gamescope), and the shared pad allow-list.
export SDL_JOYSTICK_ALLOW_BACKGROUND_EVENTS=1
export SDL_JOYSTICK_HIDAPI="${SDL_JOYSTICK_HIDAPI:-0}"
export SDL_GAMECONTROLLER_IGNORE_DEVICES_EXCEPT="${SDL_GAMECONTROLLER_IGNORE_DEVICES_EXCEPT:-{{ dg_pc_racing_gamepad_only }}}"

# The emulator resolves scripts/, CFG/, NVDATA/ and EMULATOR.INI
# relative to its CWD.
cd "$install_dir"

# Select+Start on any connected pad quits: evsieve watches the pads
# (no grab) and injects Alt+F4 (WM_CLOSE) on a virtual keyboard when
# the chord fires. NOT Escape — in this emulator Esc only leaves
# fullscreen back to windowed mode. Same pattern as azahar-launch.
evsieve_pid=""
if command -v evsieve >/dev/null 2>&1 && [ -w /dev/uinput ]; then
  pad_inputs=""
  for l in /dev/input/by-id/*8BitDo*Ultimate*event-joystick \
           /dev/input/by-id/*Xbox*event-joystick \
           /dev/input/by-id/*XBOX*event-joystick; do
    [ -e "$l" ] && pad_inputs="$pad_inputs --input $(readlink -f "$l")"
  done
  if [ -n "$pad_inputs" ]; then
    # shellcheck disable=SC2086
    evsieve $pad_inputs \
      --hook btn:select btn:start send-key=key:leftalt send-key=key:f4 \
      --output name="m2emulator-exit-keys" key:leftalt key:f4 >/dev/null 2>&1 &
    evsieve_pid=$!
  fi
fi

cleanup() {
  [ -n "$evsieve_pid" ] && kill "$evsieve_pid" 2>/dev/null || true
  env -u PYTHONHOME -u PYTHONPATH wineserver -k >/dev/null 2>&1 || true
}
trap cleanup EXIT HUP INT TERM

# gamescope hosts the exclusive-fullscreen mode (AutoFull=1) that scaled
# XWayland cannot otherwise provide; the Hyprland gamescope class rule
# fullscreens it. The game renders 4:3 ({{ dg_m2_game_width }}x{{ dg_m2_game_height }})
# via -w/-h; `-S fit` makes gamescope scale it into the 16:9 output
# ({{ dg_m2_gamescope_width }}x{{ dg_m2_gamescope_height }}) preserving
# aspect (centered pillarbox, black bars). WITHOUT -S fit the default
# scaler stretches the 4:3 surface to 16:9 (distorted); Model 2 has no
# real widescreen so stretch is the wrong result.
if command -v gamescope >/dev/null 2>&1; then
  # gamescope only exits once its entire child process tree is empty.
  # `wine <exe>` returns when the emulator quits, but wine's background
  # winedevice.exe service keeps running — so gamescope would hang as an
  # empty, unclosable window (and block the wait below). Kill wineserver
  # from inside the gamescope child right after the emulator returns so
  # winedevice dies and gamescope can exit cleanly.
  env -u PYTHONHOME -u PYTHONPATH gamescope \
    -W {{ dg_m2_gamescope_width }} \
    -H {{ dg_m2_gamescope_height }} \
    -w {{ dg_m2_game_width }} \
    -h {{ dg_m2_game_height }} \
    -S fit \
    -f \
    -- sh -c '
      env -u PYTHONHOME -u PYTHONPATH wine "$@"
      env -u PYTHONHOME -u PYTHONPATH wineserver -k >/dev/null 2>&1 || true
    ' _ "$exe" "$romset" "$@" &
else
  env -u PYTHONHOME -u PYTHONPATH wine "$exe" "$romset" "$@" &
fi
game_pid=$!
set +e
wait "$game_pid"
status=$?
set -e
trap - EXIT HUP INT TERM
cleanup
exit "$status"
