#!/usr/bin/env sh
# melonds-launch — run melonDS with the 8BitDo left analog stick also
# driving the DS d-pad.
#
# The DS only has a d-pad and melonDS can bind exactly ONE input per
# direction (hat OR axis, never both). To get the stick working *as
# well as* the physical d-pad, we synthesize hat events from the stick
# with evsieve on a virtual pad, then point melonDS at that pad.
#
# Topology: evsieve reads the real 8BitDo (no grab), passes all its
# events through unchanged, and ADDS hat0x/hat0y events derived from
# the left stick (ABS_X/ABS_Y, +-32768, 50% threshold). The virtual
# pad therefore carries the real buttons + real d-pad + stick-as-d-pad.
# melonDS is pointed at it via a scratch XDG_CONFIG_HOME whose only
# change from the real config is JoystickID -> the virtual pad's index,
# so the real melonDS config is never mutated and a crash leaves
# nothing to clean up.
#
# Falls back to a plain melonDS launch (real pad, d-pad only) when the
# 8BitDo isn't connected or evsieve/uinput are unavailable — so this
# never blocks starting a game.

set -eu

REAL_CFG="${XDG_CONFIG_HOME:-$HOME/.config}/melonDS"
VPAD_NAME="melonDS-vpad"

plain() { exec melonDS -f "$@"; }

# 8BitDo Ultimate 2 event-joystick node, resolved by stable by-id link
# (the eventN number shifts every time the pad wakes; the by-id symlink
# does not). Empty if the pad is asleep/absent.
pad_node=""
for l in /dev/input/by-id/*8BitDo*Ultimate*event-joystick; do
  [ -e "$l" ] && { pad_node=$(readlink -f "$l"); break; }
done

if [ -z "$pad_node" ] || ! command -v evsieve >/dev/null 2>&1 \
   || [ ! -w /dev/uinput ]; then
  plain "$@"
fi

# evsieve pipeline (background):
#   1. Left stick (ABS_X/Y, +-32768, 50% threshold) -> d-pad hat, so the
#      stick drives movement alongside the physical d-pad.
#   2. Gamepad-friendly hotkey combos (Select is the modifier):
#        Select+Start -> quit melonDS (SIGINT; melonDS ignores SIGTERM)
#        Select+L1    -> load state slot 1 (melonDS shortcut F1)
#        Select+R1    -> save state slot 1 (melonDS shortcut Shift+F1)
#      send-key emits the keyboard shortcuts on a SEPARATE virtual
#      keyboard device (melonDS reads save/load via Qt keyboard focus,
#      not the joystick), routed by the first --output's key filter.
#   --withhold btn:select drops Select only when it triggers a combo,
#   so the game never sees a stray Select press; L1/R1/Start stay
#   fully responsive as normal DS buttons (they leak harmlessly if
#   part of a combo, which is fine — load overwrites, quit exits).
evsieve --input "$pad_node" \
  --copy abs:x:~15999..16000~   abs:hat0x:1  \
  --copy abs:x:16000~..~15999   abs:hat0x:0  \
  --copy abs:x:-15999~..~-16000 abs:hat0x:-1 \
  --copy abs:x:~-16000..-15999~ abs:hat0x:0  \
  --copy abs:y:~15999..16000~   abs:hat0y:1  \
  --copy abs:y:16000~..~15999   abs:hat0y:0  \
  --copy abs:y:-15999~..~-16000 abs:hat0y:-1 \
  --copy abs:y:~-16000..-15999~ abs:hat0y:0  \
  --hook btn:select btn:start exec-shell="pkill -INT -x melonDS" \
  --hook btn:select btn:tl    send-key=key:f1 \
  --hook btn:select btn:tr    send-key=key:leftshift send-key=key:f1 \
  --withhold btn:select \
  --output name="melonDS-keys" key:f1 key:leftshift \
  --output name="$VPAD_NAME" >/dev/null 2>&1 &
evsieve_pid=$!

cleanup() { kill "$evsieve_pid" 2>/dev/null || true; [ -n "${scratch:-}" ] && rm -rf "$scratch" 2>/dev/null || true; }
trap cleanup EXIT INT TERM HUP

# Wait for the virtual pad to enumerate, then find its SDL index.
vpad_index=""
i=0
while [ "$i" -lt 25 ]; do
  vpad_index=$(python3 - "$VPAD_NAME" <<'PY' 2>/dev/null || true
import ctypes, ctypes.util, sys
sdl = ctypes.CDLL(ctypes.util.find_library('SDL2'))
sdl.SDL_Init(0x200)
sdl.SDL_JoystickNameForIndex.restype = ctypes.c_char_p
for j in range(sdl.SDL_NumJoysticks()):
    n = sdl.SDL_JoystickNameForIndex(j)
    if n and n.decode() == sys.argv[1]:
        print(j); break
PY
)
  [ -n "$vpad_index" ] && break
  i=$((i + 1)); sleep 0.2
done

# evsieve or SDL didn't come up as expected -> kill the synth and fall
# back to a plain launch on the real pad (d-pad only). Must stop
# evsieve first: plain() execs, dropping the cleanup trap.
if [ -z "$vpad_index" ]; then
  kill "$evsieve_pid" 2>/dev/null || true
  plain "$@"
fi

# Scratch config: copy the real melonDS config, override only the pad
# index. Absolute BIOS/firmware paths and per-ROM saves are unaffected.
scratch=$(mktemp -d)
mkdir -p "$scratch/melonDS"
cp -a "$REAL_CFG/." "$scratch/melonDS/" 2>/dev/null || true
python3 - "$scratch/melonDS/melonDS.toml" "$vpad_index" <<'PY'
import re, sys
p, idx = sys.argv[1], sys.argv[2]
try:
    t = open(p).read()
except FileNotFoundError:
    t = "[Instance0]\nJoystickID = 0\n"
# Set JoystickID under [Instance0] (first occurrence, the pad selector).
t, n = re.subn(r'(\[Instance0\][^\[]*?JoystickID = )\d+', r'\g<1>' + idx, t, count=1, flags=re.S)
if n == 0:
    t = t.replace('[Instance0]', f'[Instance0]\nJoystickID = {idx}', 1)
open(p, 'w').write(t)
PY

# NOT exec: melonDS runs as a child so we can sync its config changes
# back and the EXIT trap can stop evsieve + remove the scratch config.
# `|| true` so set -e doesn't skip the sync-back when melonDS exits
# non-zero (SIGINT quit returns 130).
XDG_CONFIG_HOME="$scratch" melonDS -f "$@" || true

# Sync in-app config changes (screen layout, window size, filtering,
# etc.) from the scratch config back to the real one, but force
# JoystickID back to 0 so a plain (non-wrapper) launch uses the real
# pad at index 0. Without this, every setting changed while playing
# via the wrapper would be lost when the scratch dir is deleted.
if [ -f "$scratch/melonDS/melonDS.toml" ]; then
  python3 - "$scratch/melonDS/melonDS.toml" "$REAL_CFG/melonDS.toml" <<'PY' || true
import re, sys
scratch_toml, real_toml = sys.argv[1], sys.argv[2]
t = open(scratch_toml).read()
t = re.sub(r'(\[Instance0\][^\[]*?JoystickID = )\d+', r'\g<1>0', t, count=1, flags=re.S)
open(real_toml, 'w').write(t)
PY
fi
