#!/usr/bin/env sh
set -eu

# ES-DE launcher for Supermodel (Sega Model 3).
#
# The AUR package's /usr/bin/supermodel wrapper is unusable from a
# frontend: it ignores its arguments entirely (launches a bare
# supermodel-binary with no ROM), hard-fails behind a zenity prompt
# unless a ROMs dir exists, and seeds ~/.config/supermodel — a path
# this build never reads. The actual binary (0.3a-WIP, checked
# 2026-07-13) resolves everything under ~/.supermodel/ absolutely:
#   ~/.supermodel/Config/   Games.xml, Music.xml, Supermodel.ini
#   ~/.supermodel/NVRAM, Saves, Screenshots, Assets
# This wrapper seeds that layout from /usr/share/supermodel on first
# run, then passes the ROM (and any extra flags) straight through.

sm_dir="$HOME/.supermodel"

if [ ! -f "$sm_dir/Config/Games.xml" ]; then
  install -Dm644 /usr/share/supermodel/Config/Games.xml "$sm_dir/Config/Games.xml"
fi
if [ ! -f "$sm_dir/Config/Music.xml" ]; then
  install -Dm644 /usr/share/supermodel/Config/Music.xml "$sm_dir/Config/Music.xml"
fi
if [ ! -d "$sm_dir/Assets" ]; then
  cp -r /usr/share/supermodel/Assets "$sm_dir/"
fi
mkdir -p "$sm_dir/NVRAM" "$sm_dir/Saves" "$sm_dir/Screenshots"

# Select+Start on any connected pad quits (Supermodel's UIExit is
# Escape): evsieve watches the pads (no grab) and injects Esc on a
# virtual keyboard when the chord fires. Same pattern as azahar-launch.
evsieve_pid=""
if command -v evsieve >/dev/null 2>&1 && [ -w /dev/uinput ]; then
  pad_inputs=""
  for l in /dev/input/by-id/*8BitDo*Ultimate*event-joystick \
           /dev/input/by-id/*Xbox*event-joystick \
           /dev/input/by-id/*XBOX*event-joystick; do
    [ -e "$l" ] && pad_inputs="$pad_inputs --input $(readlink -f "$l")"
  done
  if [ -n "$pad_inputs" ]; then
    # shellcheck disable=SC2086
    evsieve $pad_inputs \
      --hook btn:select btn:start send-key=key:esc \
      --output name="supermodel-exit-keys" key:esc >/dev/null 2>&1 &
    evsieve_pid=$!
  fi
fi
cleanup() { [ -n "$evsieve_pid" ] && kill "$evsieve_pid" 2>/dev/null || true; }
trap cleanup EXIT INT TERM HUP

# WAYLAND_DISPLAY='' forces SDL2 onto XWayland; the existing Hyprland
# gaming rule fullscreens the supermodel window class. NOT exec: the
# binary runs as a child so the trap stops evsieve on exit.
env WAYLAND_DISPLAY='' /usr/bin/supermodel-binary "$@"
