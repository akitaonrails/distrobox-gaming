#!/usr/bin/env sh
# Host launcher for Hedge Mod Manager managed by distrobox-gaming.
set -eu

BOX_NAME={{ dg_box_name | quote }}
IN_BOX_WRAPPER={{ dg_hmm_bin | quote }}

run_in_box() {
  distrobox-enter -n "$BOX_NAME" -- "$IN_BOX_WRAPPER" "$@"
}

usage() {
  cat <<EOF
Usage:
  $(basename "$0")                 # interactive picker, or plain HMM if no games found
  $(basename "$0") menu            # interactive picker
  $(basename "$0") list            # list installed supported Sonic games
  $(basename "$0") all             # list all HMM-supported Sonic Steam games
  $(basename "$0") keys            # print completion keys and aliases
  $(basename "$0") <key-or-alias>  # preselect game, then launch HMM

Examples:
  $(basename "$0") frontiers
  $(basename "$0") origins
  $(basename "$0") sxsg
EOF
}

pick_with_fzf() {
  run_in_box list \
    | awk -F '\t' '{ aliases = ($5 == "" ? "" : " [" $5 "]"); printf "%s\t%s\t%s\t%s%s\n", $1, $2, $3, $4, aliases }' \
    | fzf --prompt='HedgeModManager> ' --with-nth=4,1,2,5 --delimiter='\t' \
    | awk -F '\t' '{print $1}'
}

pick_with_menu() {
  tmp=$(mktemp)
  trap 'rm -f "$tmp"' EXIT HUP INT TERM
  run_in_box list >"$tmp"

  [ -s "$tmp" ] || return 1

  echo "Installed HMM-supported Sonic games:"
  awk -F '\t' '{ printf "%2d) %-28s %s\n", NR, $1, $4 }' "$tmp"
  printf 'Pick number or type key/alias: ' >&2
  IFS= read -r choice
  [ -n "$choice" ] || exit 1

  case "$choice" in
    *[!0-9]*) printf '%s\n' "$choice" ;;
    *) awk -F '\t' -v n="$choice" 'NR == n { print $1 }' "$tmp" ;;
  esac
}

menu() {
  [ -t 0 ] || {
    usage >&2
    exit 2
  }

  if command -v fzf >/dev/null 2>&1; then
    key=$(pick_with_fzf || true)
  else
    key=$(pick_with_menu || true)
  fi

  if [ -n "${key:-}" ]; then
    run_in_box "$key"
  else
    echo "No installed supported Sonic games detected; launching Hedge Mod Manager." >&2
    run_in_box
  fi
}

case "${1:-}" in
  -h|--help)
    usage
    ;;
  ""|menu)
    menu
    ;;
  list|all|keys|path)
    run_in_box "$@"
    ;;
  *)
    run_in_box "$@"
    ;;
esac
