# Machine-specific overrides.
# Copy to localhost.yml and edit for your setup.
#
# UID/GID used inside the container (match your NAS / file-owner uid).
# dg_host_uid: 1000
# dg_host_gid: 1000
#
# Host data/ROM layout. Defaults assume this maintainer's local mounts;
# point these at your own writable storage and game/BIOS library.
# dg_data_root: /home/me/gaming
# dg_external_games_root: /media/games
# dg_emudeck_root: "{{ dg_external_games_root }}/EmuDeck"
# dg_roms_final_root: "{{ dg_external_games_root }}/ROMS_FINAL"
# dg_external_usb_games_root: /run/media/me/STEAM
#
# Roots derived from dg_emudeck_root (override individually only if
# your layout diverges from EmuDeck's default):
# dg_rom_root:        "{{ dg_emudeck_root }}/roms"
# dg_rom_heavy_root:  "{{ dg_emudeck_root }}/roms_heavy"
# dg_rom_rare_root:   "{{ dg_emudeck_root }}/roms_rare"
# dg_bios_root:       "{{ dg_emudeck_root }}/Emulation/bios"
#
# libretro cheat DB (clone of github.com/libretro/libretro-database).
# Used by DuckStation to pull GT2 widescreen fix packs. Skip this
# variable if you don't clone the DB — the DuckStation cheats task
# warns and moves on if the source is missing.
# dg_libretro_cheats_dir: /path/to/libretro-database/cht
#
# PCSX2 texture-pack root. Expects GT4/Enthusia asset subdirs
# below (see docs/setup-assets.md for the exact filenames + links).
# Skip if you don't want PCSX2 texture replacements.
# dg_pcsx2_ps2_root: /path/to/ps2
#
# PS3 DLC/patch staging dir (PKG files per title-ID subdir).
# dg_ps3_dlc_source: "{{ dg_rom_heavy_root }}/ps3-DLC"
#
# Switch updates staging dir (NSP files).
# dg_switch_updates_source: "{{ dg_rom_heavy_root }}/switch_updates"
#
# External Steam library root used by optional Steam-game fix roles. Point at
# the directory that contains steamapps/, not steamapps itself.
# dg_external_usb_games_root: /run/media/me/STEAM
# dg_mgs_master_steam_library_root: "{{ dg_external_usb_games_root }}"
# dg_mgs_master_steam_localconfig: /home/me/.local/share/Steam/userdata/<steamid>/config/localconfig.vdf
#
# shadPS4 DLC/addon install dir (kept OUTSIDE the PS4 game tree so
# ES-DE's .bin scan doesn't pick up addon files as fake games).
# dg_shadps4_addon_install_dir: "{{ dg_emudeck_root }}/roms_rare/ps4-addons"
#
# ES-DE scraped-media root (media-symlinks task bridges EmuDeck/Skraper
# art into it; see roles/configure_esde/tasks/media-symlinks.yml).
# dg_esde_media_dir: "{{ dg_box_home }}/ES-DE/downloaded_media"
#
# Steam localconfig.vdf for the lib32-NVIDIA launch-option role.
# Account-specific — find yours under Steam userdata/<steamid>/config/.
# dg_steam_lib32_nvidia_localconfig: /path/to/Steam/userdata/<steamid>/config/localconfig.vdf
#
# 7th Heaven / MateriaForge install root. The 7th-heaven wrapper also
# honors the DG_7TH_HEAVEN_INSTALL_ROOT env var at runtime if you
# installed 7th Heaven somewhere else interactively.
# dg_7th_heaven_install_root: "{{ dg_box_home }}/tools/7th-heaven"
#
# SMM2 offline levels (opt-in role install_smm2_levels). Profile UUID is
# machine-specific: ls <eden>/nand/user/save/0000000000000000/.
# dg_smm2_eden_profile: <YOUR-EDEN-PROFILE-UUID>
# dg_smm2_levels_max_uploaded: "2019-10-01"   # "" once game updated to 3.x
#
# SDL controller allow-list for the pc-racing games (comma-separated
# 0xVID/0xPID). Add your pads' IDs (lsusb) — unlisted devices stay
# invisible to the old games on purpose (filters phantom HID pads).
# dg_pc_racing_gamepad_only: "0x2dc8/0x310b,0x045e/0x0b12"
