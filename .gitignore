.dg-state/
config/distrobox-gaming.env
*.bak
*.bak.*
*.log
config/desktop/rendered/

# Ansible local overrides and retry files.
ansible/host_vars/localhost.yml
*.retry

# Tooling artifacts (Claude Code scheduled tasks, Lobster staging, ai-jail).
.claude/
.lobster/
.ai-jail
.codex

# Python bytecode.
__pycache__/
*.pyc

# Never commit emulator runtime state, saves, firmware, ROMs, or caches.
runtime/
roms/
bios/
firmware/
sys_modules/
game_data/
cache/
shader/
saves/
states/
screenshots/
captures/
