[Desktop Entry]
Name=shadPS4 Driveclub (on @DG_BOX_NAME@)
Exec=/usr/bin/distrobox-enter -n @DG_BOX_NAME@ -- @DG_SHADPS4_BIN@ -g @DG_SHADPS4_GAME_ARG@ -p @DG_SHADPS4_PATCH_XML@ -f true
Terminal=false
Type=Application
Icon=shadps4
Comment=PlayStation 4 emulator configured for Driveclub
Categories=Game;Emulator;
StartupWMClass=shadps4;
