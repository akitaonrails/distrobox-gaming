# Distrobox identity.
DG_BOX_NAME=gaming
DG_IMAGE=archlinux:latest

# Host/container user identity. Leave blank to auto-detect from the host.
DG_HOST_UID=
DG_HOST_GID=
DG_HOST_USER=
DG_HOST_GROUP=

# Box storage. Change DG_DATA_ROOT if your writable storage is not /mnt/data.
DG_DATA_ROOT=/mnt/data
DG_BOX_ROOT=$DG_DATA_ROOT/distrobox/gaming
DG_BOX_HOME=$DG_BOX_ROOT

# EmuDeck/NAS roots. Change these if your ROMs/BIOS live elsewhere.
DG_EMUDECK_ROOT=/mnt/terachad/Emulators/EmuDeck
DG_ROM_ROOT=/mnt/terachad/Emulators/EmuDeck/roms
DG_ROM_HEAVY_ROOT=/mnt/terachad/Emulators/EmuDeck/roms_heavy
DG_ROM_RARE_ROOT=/mnt/terachad/Emulators/EmuDeck/roms_rare
DG_BIOS_ROOT=/mnt/terachad/Emulators/EmuDeck/Emulation/bios

# shadPS4 / Driveclub defaults. Keep the PS4 root clean: extracted game
# directories only, one title ID directory per game.
DG_PS4_ROM_ROOT=/mnt/terachad/Emulators/EmuDeck/roms_rare/ps4
DG_PS4_FIRMWARE_MODULES=/mnt/terachad/Emulators/EmuDeck/roms_rare/ps4-firmware/11.00_sys_modules
DG_SHADPS4_TITLE_ID=CUSA00003
DG_SHADPS4_GAME_DIR=/mnt/terachad/Emulators/EmuDeck/roms_rare/ps4/CUSA00003
DG_SHADPS4_PATCH_NAME=Driveclub.xml
DG_SHADPS4_QTLAUNCHER_ROOT=$DG_BOX_HOME/tools/shadps4-qtlauncher
DG_SHADPS4_QTLAUNCHER_RELEASE=2026-04-12-51b62bd
DG_SHADPS4_QTLAUNCHER_RELEASES_API=https://api.github.com/repos/shadps4-emu/shadps4-qtlauncher/releases
DG_SHADPS4_QTLAUNCHER_ASSET_NAME=shadPS4QtLauncher-qt.AppImage
DG_SHADPS4_QTLAUNCHER_BIN=$DG_BOX_HOME/bin/shadps4-qtlauncher-current
DG_SHADPS4_VERSIONS_ROOT=$DG_BOX_HOME/.local/share/shadPS4QtLauncher/versions
DG_SHADPS4_RELEASES_API=https://api.github.com/repos/shadps4-emu/shadPS4/releases
DG_SHADPS4_CHANNEL=Pre-release
DG_SHADPS4_MANAGED_BIN=$DG_SHADPS4_VERSIONS_ROOT/$DG_SHADPS4_CHANNEL/Shadps4-sdl.AppImage
DG_SHADPS4_BIN=$DG_BOX_HOME/bin/shadps4-current

# Dolphin + xemu local runtime state. xemu links BIOS/HDD files from the BIOS
# root into box-local paths so the emulator config stays stable across rebuilds.
DG_DOLPHIN_CONFIG_DIR=$DG_BOX_HOME/.config/dolphin-emu
DG_XEMU_CONFIG_DIR=$DG_BOX_HOME/.config/xemu
DG_XEMU_DATA_DIR=$DG_BOX_HOME/.local/share/xemu
DG_XEMU_CONFIG=$DG_XEMU_CONFIG_DIR/xemu.toml
DG_XEMU_BOOTROM_SOURCE=$DG_BIOS_ROOT/mcpx_1.0.bin
DG_XEMU_FLASHROM_SOURCE=$DG_BIOS_ROOT/Complex_4627.bin
DG_XEMU_HDD_SOURCE=$DG_BIOS_ROOT/xbox_hdd.qcow2
DG_XEMU_BOOTROM=$DG_XEMU_CONFIG_DIR/mcpx_1.0.bin
DG_XEMU_FLASHROM=$DG_XEMU_CONFIG_DIR/Complex_4627.bin
DG_XEMU_HDD=$DG_XEMU_DATA_DIR/xbox_hdd.qcow2

# Xenia Manager / Wine prefix. Xenia Manager installs Canary itself inside the
# same prefix, so there is no separate native Linux Xenia package to manage.
DG_XENIA_PREFIX=$DG_BOX_HOME/wineprefixes/xenia-manager
DG_XENIA_CACHE_DIR=$DG_BOX_HOME/cache/xenia-manager
DG_XENIA_MANAGER_RELEASES_DIR=$DG_BOX_HOME/tools/xenia-manager/releases
DG_XENIA_MANAGER_CURRENT=$DG_BOX_HOME/tools/xenia-manager/current
DG_XENIA_MANAGER_EXE=$DG_XENIA_MANAGER_CURRENT/XeniaManager.exe
DG_XENIA_MANAGER_BIN=$DG_BOX_HOME/bin/xenia-manager
DG_XENIA_MANAGER_RELEASE_API=https://api.github.com/repos/xenia-manager/xenia-manager/releases/latest
DG_XENIA_MANAGER_ZIP_URL=
DG_XENIA_DOTNET_URL=https://aka.ms/dotnet/10.0/windowsdesktop-runtime-win-x64.exe
DG_XENIA_VCREDIST_URL=https://aka.ms/vs/17/release/vc_redist.x64.exe
DG_XENIA_GAME_DIR=$DG_ROM_ROOT/xbox360

# Existing legacy notes source. Used only by documentation import tasks.
DG_LEGACY_DOCS_ROOT=/mnt/terachad/Documents/FrankMD/Linux

# Host desktop integration.
DG_HOST_APPLICATIONS_DIR=$HOME/.local/share/applications
