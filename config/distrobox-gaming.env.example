# Distrobox identity.
DG_BOX_NAME=gaming
DG_IMAGE=archlinux:latest

# Host/container user identity. Leave blank to auto-detect from the host.
DG_HOST_UID=
DG_HOST_GID=
DG_HOST_USER=
DG_HOST_GROUP=

# Box storage. This is where the gaming box home/config state lives.
DG_BOX_ROOT=/mnt/data/distrobox/gaming
DG_BOX_HOME=/mnt/data/distrobox/gaming

# EmuDeck/NAS roots. Change these if your ROMs/BIOS live elsewhere.
DG_EMUDECK_ROOT=/mnt/terachad/Emulators/EmuDeck
DG_ROM_ROOT=/mnt/terachad/Emulators/EmuDeck/roms
DG_ROM_HEAVY_ROOT=/mnt/terachad/Emulators/EmuDeck/roms_heavy
DG_ROM_RARE_ROOT=/mnt/terachad/Emulators/EmuDeck/roms_rare
DG_BIOS_ROOT=/mnt/terachad/Emulators/EmuDeck/Emulation/bios

# shadPS4 / Driveclub defaults. Keep the PS4 root clean: extracted game
# directories only, one title ID directory per game.
DG_PS4_ROM_ROOT=/mnt/terachad/Emulators/EmuDeck/roms_rare/ps4
DG_PS4_FIRMWARE_MODULES=/mnt/terachad/Emulators/EmuDeck/roms_rare/ps4-firmware/11.00_sys_modules
DG_SHADPS4_TITLE_ID=CUSA00003
DG_SHADPS4_GAME_DIR=/mnt/terachad/Emulators/EmuDeck/roms_rare/ps4/CUSA00003
DG_SHADPS4_PATCH_NAME=Driveclub.xml
DG_SHADPS4_RUNTIME_ROOT=/mnt/data/distrobox/gaming/tools/shadps4-nightly
DG_SHADPS4_RUNTIME_RELEASE=2026-04-09-e16a59b
DG_SHADPS4_BIN=/mnt/data/distrobox/gaming/bin/shadps4-current
DG_SHADPS4_QTLAUNCHER_ROOT=/mnt/data/distrobox/gaming/tools/shadps4-qtlauncher
DG_SHADPS4_QTLAUNCHER_RELEASE=2026-04-09-30ad647
DG_SHADPS4_QTLAUNCHER_BIN=/mnt/data/distrobox/gaming/bin/shadps4-qtlauncher-current

# Existing legacy notes source. Used only by documentation import tasks.
DG_LEGACY_DOCS_ROOT=/mnt/terachad/Documents/FrankMD/Linux

# Host desktop integration.
DG_HOST_APPLICATIONS_DIR=$HOME/.local/share/applications
